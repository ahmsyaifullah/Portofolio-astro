---
// src/pages/index.astro
// Halaman utama – mengintegrasikan semua komponen
// Blog data di-fetch saat build time menggunakan fetchBlog.js

import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Tentang from '../components/Tentang.astro';
import Keahlian from '../components/Keahlian.astro';
import Proyek from '../components/Proyek.astro';
import BlogPreview from '../components/BlogPreview.astro';
import Kontak from '../components/Kontak.astro';
import Footer from '../components/Footer.astro';
import { fetchBlog } from '../utils/fetchBlog.js';

// Fetch artikel saat build time (server-side, bukan client-side)
const blogPosts = await fetchBlog();
---

<BaseLayout
  title="Ahmad Syaifullah | Spesialis Administrasi Sekolah & Keuangan"
  description="Ahmad Syaifullah, spesialis Administrasi Sekolah, pengelolaan Dana BOS, Dapodik, BPJS, dan Pelaporan Keuangan. Berbasis di Pontianak, Indonesia."
>
  <Navbar />
  <main>
    <Hero />
    <Tentang />
    <Keahlian />
    <Proyek />
    <BlogPreview posts={blogPosts} />
    <Kontak />
  </main>
  <Footer />
</BaseLayout>