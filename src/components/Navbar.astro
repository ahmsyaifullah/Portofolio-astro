---
// src/components/Navbar.astro
// Sticky navbar sesuai layout dasar-ui-ux.html
// Konten sesuai plan.md: Beranda, Tentang Saya, Keahlian, Proyek, Kontak | Blog → eksternal
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
---

<nav class="sticky top-0 z-50 w-full border-b border-slate-100 bg-white/90 backdrop-blur-md transition-all">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 lg:px-8">

    <!-- Logo -->
    <a class="flex items-center" href="#beranda">
      <Image
        src={logo}
        alt="Ahmad Syaifullah"
        class="h-9 w-auto rounded-xl shadow-sm"
        loading="eager"
        style="object-fit: contain;"
      />
    </a>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-8">
      <a class="text-sm font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#beranda">Beranda</a>
      <a class="text-sm font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#tentang">Tentang Saya</a>
      <a class="text-sm font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#keahlian">Keahlian</a>
      <a class="text-sm font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#proyek">Proyek</a>
      <a class="text-sm font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#kontak">Kontak</a>
      <a
        class="text-sm font-medium text-slate-600 hover:text-[#2563EB] transition-colors"
        href="https://ragamtutorial.web.id"
        target="_blank"
        rel="noopener noreferrer"
      >Blog</a>
    </div>

    <!-- CTA + Mobile Button -->
    <div class="flex items-center gap-4">
      <a
        class="hidden sm:inline-flex h-9 items-center justify-center rounded bg-[#0F172A] px-4 text-sm font-medium text-white shadow transition-colors hover:bg-[#0F172A]/90 focus-visible:outline-none focus-visible:ring-1"
        href="#kontak"
      >
        Hubungi Saya
      </a>
      <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-[#0F172A]" aria-label="Buka menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>

  </div>
</nav>

<!-- Mobile Menu (Hidden by default) -->
<div id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-100 px-6 py-4 space-y-4 shadow-sm absolute w-full z-40">
  <div class="flex flex-col gap-4">
    <a class="text-base font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#beranda">Beranda</a>
    <a class="text-base font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#tentang">Tentang Saya</a>
    <a class="text-base font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#keahlian">Keahlian</a>
    <a class="text-base font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#proyek">Proyek</a>
    <a class="text-base font-medium text-slate-600 hover:text-[#2563EB] transition-colors" href="#kontak">Kontak</a>
    <a
      class="text-base font-medium text-slate-600 hover:text-[#2563EB] transition-colors"
      href="https://ragamtutorial.web.id"
      target="_blank"
      rel="noopener noreferrer"
    >Blog</a>
    <a
      class="inline-flex h-10 w-full mt-2 items-center justify-center rounded bg-[#0F172A] px-4 text-sm font-medium text-white shadow transition-colors hover:bg-[#0F172A]/90"
      href="#kontak"
    >
      Hubungi Saya
    </a>
  </div>
</div>

<script>
  // Mobile menu toggle logic
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });

    // Close menu when clicking a link inside it
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>
