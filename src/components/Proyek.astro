---
// src/components/Proyek.astro
// 3 studi kasus persis sesuai plan.md – layout article card dari dasar-ui-ux.html
// Format: Permasalahan → Solusi → Hasil – sudut pandang saya (orang pertama)
import { Image } from 'astro:assets';
import imgEdmErkam from '../assets/proyek-edm-erkam.webp';
import imgEmis from '../assets/proyek-emis.webp';
import imgBpjs from '../assets/proyek-bpjs.webp';
---

<section class="py-24 bg-[#F8FAFC] border-y border-slate-100" id="proyek">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-end mb-14 gap-4">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold text-[#2563EB] uppercase tracking-widest mb-2">Portofolio</p>
        <h2 class="text-3xl font-bold tracking-tight text-[#0F172A] sm:text-4xl">Proyek Unggulan</h2>
        <p class="mt-3 text-base text-slate-500">Studi kasus nyata dari pengalaman administrasi sekolah saya.</p>
      </div>
    </div>

    <!-- Grid 3 proyek -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Proyek 1: Optimalisasi Pelaporan Dana BOS pada aplikasi EDM & E-RKAM-->
      <article class="group flex flex-col overflow-hidden rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
        <!-- Thumbnail -->
        <div class="relative h-44 overflow-hidden bg-slate-100">
          <Image
            src={imgEdmErkam}
            alt="Optimalisasi Pelaporan Dana BOS (EDM & E-RKAM)"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          <!-- Badge di atas gambar -->
          <span class="absolute bottom-3 left-3 inline-flex items-center rounded-full bg-blue-600 px-2.5 py-0.5 text-xs font-medium text-white shadow">
            Keuangan Sekolah
          </span>
        </div>

        <!-- Body -->
        <div class="flex flex-1 flex-col p-5 gap-4">
          <h3 class="text-base font-bold text-[#0F172A] leading-snug">
            Optimalisasi Pelaporan Dana BOS (EDM & E-RKAM)
          </h3>

          <!-- Studi Kasus Timeline -->
          <div class="flex flex-col gap-3 text-sm">
            <!-- Permasalahan -->
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-red-50 border border-red-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-red-500" style="font-size:14px">error_outline</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Permasalahan</p>
                <p class="text-slate-500 leading-relaxed">Tim pengelola BOS masih asing dengan sistem digital EDM & E-RKAM yang menggantikan pola manual, berisiko menyebabkan ketidaksesuaian data belanja.</p>
              </div>
            </div>
            <!-- Divider -->
            <div class="ml-3 w-px h-3 bg-slate-200 self-center"></div>
            <!-- Solusi -->
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-blue-50 border border-blue-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-blue-500" style="font-size:14px">build_circle</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Solusi</p>
                <p class="text-slate-500 leading-relaxed">Memberikan pendampingan teknis dan pelatihan intensif kepada Bendahara & Kepala Madrasah mengenai alur kerja aplikasi sesuai standar Kemenag.</p>
              </div>
            </div>
            <!-- Divider -->
            <div class="ml-3 w-px h-3 bg-slate-200 self-center"></div>
            <!-- Hasil -->
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-green-50 border border-green-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-green-600" style="font-size:14px">check_circle</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Hasil</p>
                <p class="text-slate-500 leading-relaxed">Digitalisasi pelaporan berjalan sukses. Seluruh data realisasi tersinkronisasi di E-RKAM, laporan selesai tepat waktu dan <strong class="text-[#0F172A]">100% patuh regulasi</strong>.</p>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- Proyek 2: Perapian Database EMIS -->
      <article class="group flex flex-col overflow-hidden rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
        <!-- Thumbnail -->
        <div class="relative h-44 overflow-hidden bg-slate-100">
          <Image
            src={imgEmis}
            alt="Data EMIS siswa dan guru"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          <span class="absolute bottom-3 left-3 inline-flex items-center rounded-full bg-emerald-600 px-2.5 py-0.5 text-xs font-medium text-white shadow">
            Data EMIS
          </span>
        </div>

        <!-- Body -->
        <div class="flex flex-1 flex-col p-5 gap-4">
          <h3 class="text-base font-bold text-[#0F172A] leading-snug">
            Perapian Database EMIS
          </h3>

          <!-- Highlight metric -->
          <div class="flex items-center gap-3 rounded-xl bg-emerald-50 border border-emerald-100 px-4 py-3">
            <p class="text-2xl font-extrabold text-emerald-600">99%</p>
            <p class="text-xs text-emerald-700 leading-snug">Tingkat keberhasilan sinkronisasi, naik dari <strong>72%</strong></p>
          </div>

          <!-- Studi Kasus Timeline -->
          <div class="flex flex-col gap-3 text-sm">
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-red-50 border border-red-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-red-500" style="font-size:14px">error_outline</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Permasalahan</p>
                <p class="text-slate-500 leading-relaxed">Data EMIS mengandung banyak entri ganda, data tidak lengkap, dan ketidaksesuaian NISN yang mengakibatkan gagal sinkronisasi.</p>
              </div>
            </div>
            <div class="ml-3 w-px h-3 bg-slate-200 self-center"></div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-blue-50 border border-blue-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-blue-500" style="font-size:14px">build_circle</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Solusi</p>
                <p class="text-slate-500 leading-relaxed">Audit data menyeluruh, membersihkan entri duplikat, dan melengkapi data siswa menggunakan referensi silang dengan dokumen fisik sekolah.</p>
              </div>
            </div>
            <div class="ml-3 w-px h-3 bg-slate-200 self-center"></div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-green-50 border border-green-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-green-600" style="font-size:14px">check_circle</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Hasil</p>
                <p class="text-slate-500 leading-relaxed">Sinkronisasi EMIS meningkat dari <strong class="text-[#0F172A]">72% → 99%</strong>, memperlancar penerimaan dana BOS berbasis data.</p>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- Proyek 3: Administrasi BPJS Kesehatan & Ketenagakerjaan -->
      <article class="group flex flex-col overflow-hidden rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
        <!-- Thumbnail -->
        <div class="relative h-44 overflow-hidden bg-slate-100">
          <Image
            src={imgBpjs}
            alt="Administrasi BPJS Kesehatan & Ketenagakerjaan"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          <span class="absolute bottom-3 left-3 inline-flex items-center rounded-full bg-violet-600 px-2.5 py-0.5 text-xs font-medium text-white shadow">
            Administrasi BPJS
          </span>
        </div>

        <!-- Body -->
        <div class="flex flex-1 flex-col p-5 gap-4">
          <h3 class="text-base font-bold text-[#0F172A] leading-snug">
            Administrasi BPJS Kesehatan & Ketenagakerjaan
          </h3>

          <!-- Studi Kasus Timeline -->
          <div class="flex flex-col gap-3 text-sm">
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-red-50 border border-red-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-red-500" style="font-size:14px">error_outline</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Permasalahan</p>
                <p class="text-slate-500 leading-relaxed">Banyak data mantan staf yang sudah berhenti namun iurannya masih terbayar karena tercatat aktif di sistem BPJS, mengakibatkan pemborosan anggaran.</p>
              </div>
            </div>
            <div class="ml-3 w-px h-3 bg-slate-200 self-center"></div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-blue-50 border border-blue-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-blue-500" style="font-size:14px">build_circle</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Solusi</p>
                <p class="text-slate-500 leading-relaxed">Audit & rekonsiliasi data kepesertaan BPJS secara menyeluruh, memproses offboarding massal karyawan non-aktif, dan sinkronisasi dengan data kepegawaian terkini.</p>
              </div>
            </div>
            <div class="ml-3 w-px h-3 bg-slate-200 self-center"></div>
            <div class="flex gap-3">
              <div class="flex-shrink-0 mt-0.5 w-6 h-6 rounded-full bg-green-50 border border-green-200 flex items-center justify-center">
                <span class="material-symbols-outlined text-green-600" style="font-size:14px">check_circle</span>
              </div>
              <div>
                <p class="font-semibold text-[#0F172A] mb-0.5">Hasil</p>
                <p class="text-slate-500 leading-relaxed">Database administrasi rapi & akurat. Kerugian finansial akibat iuran karyawan non-aktif <strong class="text-[#0F172A]">berhasil dihentikan</strong> dan alokasi anggaran jadi lebih efektif.</p>
              </div>
            </div>
          </div>
        </div>
      </article>

    </div>

    <!-- CTA Lihat Semua Proyek -->
    <div class="mt-16 flex justify-center">
      <a
        href="/proyek"
        class="inline-flex h-12 items-center justify-center rounded-lg bg-white border-2 border-[#0F172A] px-8 text-base font-semibold text-[#0F172A] shadow-sm transition-all hover:bg-[#0F172A] hover:text-white hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#2563EB] focus-visible:ring-offset-2 group"
      >
        Lihat Semua Proyek
        <span class="material-symbols-outlined ml-2 text-xl transition-transform group-hover:translate-x-1" style="font-size: 20px;">target</span>
      </a>
    </div>

  </div>
</section>
