---
// src/components/Kontak.astro
// Layout 2 kolom dari dasar-ui-ux.html
// Konten dari plan.md: form Nama/Email/Pesan, info kontak Pontianak, ajakan kerja sama
---

<section class="py-24 bg-[#F8FAFC] border-t border-slate-100" id="kontak">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

      <!-- Kolom kiri: info kontak -->
      <div>
        <h2 class="text-3xl font-bold tracking-tight text-[#0F172A] sm:text-4xl">Mari Bekerja Sama</h2>
        <p class="mt-4 text-lg text-slate-600">
          Tertarik untuk berkolaborasi dalam pengelolaan administrasi sekolah, pelaporan keuangan, atau manajemen data pendidikan?
          Saya terbuka untuk diskusi dan kerja sama profesional. Silakan hubungi saya.
        </p>

        <div class="mt-10 space-y-6">
          <!-- Email -->
          <div class="flex items-center gap-4 text-slate-600">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white border border-slate-200 text-[#0F172A]">
              <span class="material-symbols-outlined">mail</span>
            </div>
            <span class="font-medium">contact@ahmadsyaifullah.my.id</span>
          </div>

          <!-- Lokasi -->
          <div class="flex items-center gap-4 text-slate-600">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white border border-slate-200 text-[#0F172A]">
              <span class="material-symbols-outlined">location_on</span>
            </div>
            <span class="font-medium">Pontianak, Indonesia</span>
          </div>

          <!-- Blog -->
          <div class="flex items-center gap-4 text-slate-600">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white border border-slate-200 text-[#0F172A]">
              <span class="material-symbols-outlined">link</span>
            </div>
            <a
              class="font-medium hover:text-[#2563EB] transition-colors"
              href="https://ragamtutorial.web.id"
              target="_blank"
              rel="noopener noreferrer"
            >ragamtutorial.web.id</a>
          </div>
        </div>
      </div>

      <!-- Kolom kanan: form kontak -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-200">
        <form id="form-kontak" class="space-y-6">
          <!-- Nama -->
          <div>
            <label class="block text-sm font-semibold leading-6 text-[#0F172A]" for="nama">Nama</label>
            <div class="mt-2.5">
              <input
                autocomplete="name"
                class="block w-full rounded-md border-0 px-3.5 py-2 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-[#0F172A] sm:text-sm sm:leading-6"
                id="nama"
                name="nama"
                type="text"
                placeholder="Nama lengkap Anda"
                required
              />
            </div>
          </div>

          <!-- Email -->
          <div>
            <label class="block text-sm font-semibold leading-6 text-[#0F172A]" for="email-kontak">Email</label>
            <div class="mt-2.5">
              <input
                autocomplete="email"
                class="block w-full rounded-md border-0 px-3.5 py-2 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-[#0F172A] sm:text-sm sm:leading-6"
                id="email-kontak"
                name="email"
                type="email"
                placeholder="email@domain.com"
                required
              />
            </div>
          </div>

          <!-- Pesan -->
          <div>
            <label class="block text-sm font-semibold leading-6 text-[#0F172A]" for="pesan">Pesan</label>
            <div class="mt-2.5">
              <textarea
                class="block w-full rounded-md border-0 px-3.5 py-2 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-[#0F172A] sm:text-sm sm:leading-6"
                id="pesan"
                name="pesan"
                rows="4"
                placeholder="Tulis pesan atau pertanyaan Anda di sini..."
                required
              ></textarea>
            </div>
          </div>

          <button
            class="block w-full rounded-md bg-[#0F172A] px-3.5 py-2.5 text-center text-sm font-bold text-white shadow-sm hover:bg-[#0F172A]/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0F172A] transition-colors"
            type="submit"
          >
            Kirim Pesan
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('form-kontak') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const nama = formData.get('nama')?.toString() || '';
      const email = formData.get('email')?.toString() || '';
      const pesan = formData.get('pesan')?.toString() || '';
      
      const targetEmail = 'contact@ahmadsyaifullah.my.id';
      const subject = encodeURIComponent(`Pesan via Portofolio dari ${nama}`);
      const body = encodeURIComponent(`Nama: ${nama}\nEmail: ${email}\n\nPesan:\n${pesan}`);
      
      window.location.href = `mailto:${targetEmail}?subject=${subject}&body=${body}`;
    });
  }
</script>
